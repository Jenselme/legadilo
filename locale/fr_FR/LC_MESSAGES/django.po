msgstr "Le serveur a échoué trop de fois à récupérer le flux."

#, python-format
msgid "Feed '%s' was disabled"
msgstr "Le flux '%s' est désactivé"

msgid "Edit feed"
msgstr "Éditer de flux"

msgid ""
"Define for how long in days to keep read articles associated with this feed. "
"Use 0 to always keep the articles."
msgstr ""
"Défini combien de temps les articles lus associés à ce flux sont conservés. "
"0 permet de garder les articles indéfiniment."

msgid "None"
msgstr "Aucun"

#, python-format
msgid "Articles of feed '%(feed_title)s'"
msgstr "Articles du flux '%(feed_title)s'"

msgid "Feed categories admin"
msgstr "Administration des catégories des flux"

msgid "Title"
msgstr "Titre"

msgid "Edit feed category"
msgstr "Modifier une catégorie"

msgid "Create feed category"
msgstr "Créer une catégorie de flux"

#, python-format
msgid "A category with title '%s' already exists."
msgstr "Une catégorie avec le titre '%s' existe déjà."

msgid "Feeds admin"
msgstr "Administration des flux"

msgid "Feed URL"
msgstr "URL du flux"

msgid "Site URL"
msgstr "URL du site"

msgid "Refresh delay"
msgstr "Délai d’actualisation"

msgid "Article retention period"
msgstr "Durée de rétention de l’article"

msgid "Open original by default"
msgstr "Ouvrir l’original par défaut"

msgid "Category"
msgstr "Catégorie"

msgid "The category of the feed to help you keep them organized."
msgstr "La catégorie du flux vous permez de les garder organiser."

msgid "Tags"
msgstr "Étiquettes"

msgid ""
"Tags to associate to articles of this feed. To create a new tag, type and "
"press enter. Editing this tag list will update the tags of all articles of "
"this feed."
msgstr ""
"Étiquettes à associer à ce flux. Pour en créer une nouvelle, tapez son titre "
"et appuyez sur entrée. Éditer cette liste d’étiquettes metter à jour les "
"étiquettes de tous les articles associés à ce flux."

msgid "Manually disabled"
msgstr "Désactivé manuellement"

msgid ""
"Enter the URL to the feed you want to subscribe to. If you don't know it, "
"enter the URL of the site and the server will try to find the feed for you."
msgstr ""
"Entrez l’URL du flux auquel vous voulez vous abonner. Si vous ne la "
"connaissez pas, entrez l’URL du site et le serveur essaiera de trouver le "
"flux pour vous."

msgid "Feed choices"
msgstr "Choix des flux"

msgid "Proposed feed choices"
msgstr "Propositions de flux à choisir"

msgid ""
"Tags to associate to articles of this feed. To create a new tag, type and "
"press enter."
msgstr ""
"Étiquettes à associer à ce flux. Pour créer une nouvelle étiquette, tapez "
"son titre et appuyez sur entrée."

msgid "Subscribe to a feed"
msgstr "S’abonner à un flux"

#, python-format
msgid ""
"Failed to fetch the feed. Please check that the URL you entered is correct, "
"that the feed exists, is accessible, valid and that the file is not above "
"%(max_size)s MiB."
msgstr ""
"Impossible de récupérer le flux. Merci de vérifier que l’URL est correcte, "
"que le flux existe, qu’il est publiquement accessible, valide et ne dépasse "
"pas %(max_size)s Mio."

msgid "Failed to find a feed URL on the supplied page."
msgstr "Impossible de trouver une URL de flux sur la page fournie."

msgid ""
"Multiple feeds were found at this location, please select the proper one."
msgstr "Plusieurs flux ont été trouvés, merci de sélectionner le bon."

msgid "CSV file"
msgstr "Fichier CSV"

msgid "Wallabag export file"
msgstr "Fichier d’export de Wallabag"

msgid "The supplied file is too big to be imported."
msgstr "Le fichier fourni est trop gros pour être importé."

msgid "This file type is not supported for imports."
msgstr "Ce type de fichier n’est pas supporté pour les imports."

msgid "The file you supplied is not valid."
msgstr "Le fichier fourni n’est pas valide."

#, python-format
msgid ""
"Successfully imported %(nb_imported_feeds)s feeds, "
"%(nb_imported_categories)s feed categories and %(nb_imported_articles)s "
"articles."
msgstr ""
"%(nb_imported_feeds)s flux, %(nb_imported_categories)s catégories de flux et "
"%(nb_imported_articles)s articles importés avec succès."

#, python-format
msgid "Successfully imported %s articles"
msgstr "%s articles importés avec succès"

msgid "OPML file"
msgstr "Fichier OPML"

#, python-format
msgid ""
"Successfully imported %(nb_imported_feeds)s feeds into "
"%(nb_imported_categories)s categories."
msgstr ""
"%(nb_imported_feeds)s flux et %(nb_imported_categories)s catégories importés "
"avec succès."

